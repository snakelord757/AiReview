GITHUB_WEBHOOK_SECRET=replace-with-long-random-value
# Preferred production authentication (GitHub App):
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# Or, for a simple deployment, use a fine-grained token instead:
# GITHUB_TOKEN=github_pat_...

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_EMBED_MODEL=embeddinggemma:300m
RAG_TOP_K=5
RAG_CHUNK_SIZE=1800
RAG_CHUNK_OVERLAP=200
MAX_PATCH_CHARS=60000
PORT=8080
